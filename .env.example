# Copy to .env and adjust. Everything is optional.

# PUBLIC_IP is auto-detected (via https://api.ipify.org) if you leave it unset.
# Only set it to override — e.g. behind NAT, multi-homed, or a specific advertised IP:
# PUBLIC_IP=203.0.113.10

# (optional) override the ZCore L1 subnet — defaults to the official one (on Avalanche Fuji).
# SUBNET_ID=2pTqqpENtHTi118Dh4PSbLkjA6ySpBBeRTK9emcrfksDFytAdg
