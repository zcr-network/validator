# Copy to .env and fill in.  cp .env.example .env

# Your validator operator private key (secp256k1, hex, with or without 0x).
# The SAME key is used for the EVM side (holds ZEUS, pays L1 gas) and the P-Chain
# side (holds AVAX, gets it back on unstake). Run `node whoami.mjs` to see both
# addresses derived from it, then fund them.
#   • EVM address     ← send 1 ZEUS (+ a little ZCR for gas, from the faucet)
#   • P-Chain address ← send test AVAX (Fuji faucet → Core → cross-chain C→P)
PRIVATE_KEY=

# Optional: use a separate key for the P-Chain side (defaults to PRIVATE_KEY).
# PCHAIN_PRIVATE_KEY=

# Optional: your node's API URL (defaults to the local node).
# NODE_URL=http://127.0.0.1:9650
